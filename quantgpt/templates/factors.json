  {
    "id": "momentum_20d",
    "name": "20日动量",
    "category": "momentum",
    "description": "过去20个交易日的涨幅排名，捕捉趋势延续效应",
    "expression": "rank(ts_delta(close, 20) / ts_shift(close, 20))",
    "tags": ["动量", "趋势"],
    "difficulty": "beginner",
    "suggested_params": {
      "universe": "hs300",
      "holding_period": 10,
      "n_groups": 5
    },
    "reference": "Jegadeesh & Titman (1993)"
  },
